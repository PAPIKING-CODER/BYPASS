# Copy this file to .env and fill in the values
# Never commit your .env file to git!

# Required — your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Optional — port for the health check server (default: 8080)
PORT=8080

# Optional — override the bot invite URL
BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=1525040833814855710&permissions=8&scope=bot+applications.commands
